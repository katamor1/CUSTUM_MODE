{
  "name": "bob-bazaar-review",
  "displayName": "Bob Bazaar Review",
  "description": "Companion extension that exposes Bazaar revision review tools and project rule review helpers to IBM Bob through MCP.",
  "version": "0.2.0",
  "publisher": "katamor1",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "vscode": "^1.106.1"
  },
  "categories": [
    "Other"
  ],
  "extensionDependencies": [
    "IBM.bob-code"
  ],
  "activationEvents": [
    "onCommand:bobBazaar.configureMcp",
    "onCommand:bobBazaar.initProjectRules",
    "onCommand:bobBazaar.reviewRevision",
    "onCommand:bobBazaar.reviewRange",
    "onCommand:bobBazaar.reviewRevisionWithProjectRules",
    "onCommand:bobBazaar.reviewRangeWithProjectRules",
    "onCommand:bobBazaar.validateReviewResultJson"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "bobBazaar.configureMcp",
        "title": "Configure Bazaar MCP for Bob",
        "category": "Bob Bazaar"
      },
      {
        "command": "bobBazaar.initProjectRules",
        "title": "Initialize Project Review Rules",
        "category": "Bob Bazaar"
      },
      {
        "command": "bobBazaar.reviewRevision",
        "title": "Review Bazaar Revision with Bob",
        "category": "Bob Bazaar"
      },
      {
        "command": "bobBazaar.reviewRange",
        "title": "Review Bazaar Revision Range with Bob",
        "category": "Bob Bazaar"
      },
      {
        "command": "bobBazaar.reviewRevisionWithProjectRules",
        "title": "Review Bazaar Revision with Project Rules",
        "category": "Bob Bazaar"
      },
      {
        "command": "bobBazaar.reviewRangeWithProjectRules",
        "title": "Review Bazaar Revision Range with Project Rules",
        "category": "Bob Bazaar"
      },
      {
        "command": "bobBazaar.validateReviewResultJson",
        "title": "Validate Project Review Result JSON",
        "category": "Bob Bazaar"
      }
    ],
    "configuration": {
      "title": "Bob Bazaar Review",
      "properties": {
        "bobBazaar.bzrPath": {
          "type": "string",
          "default": "bzr",
          "description": "Path to the Bazaar executable. Use an absolute path when bzr is not on PATH."
        },
        "bobBazaar.mcpServerName": {
          "type": "string",
          "default": "bazaar",
          "description": "MCP server name written to .bob/mcp.json."
        },
        "bobBazaar.maxDiffBytes": {
          "type": "number",
          "default": 1048576,
          "minimum": 32768,
          "description": "Maximum Bazaar diff size to include in the generated review packet."
        },
        "bobBazaar.projectRules.checklistPath": {
          "type": "string",
          "default": ".bob/review/checklist.json",
          "description": "Workspace-relative or absolute path to the project-specific review checklist JSON."
        },
        "bobBazaar.projectRules.schemaPath": {
          "type": "string",
          "default": ".bob/review/review-result.schema.json",
          "description": "Workspace-relative or absolute path to the review result JSON schema."
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "bobBazaar.configureMcp"
        },
        {
          "command": "bobBazaar.initProjectRules"
        },
        {
          "command": "bobBazaar.reviewRevision"
        },
        {
          "command": "bobBazaar.reviewRange"
        },
        {
          "command": "bobBazaar.reviewRevisionWithProjectRules"
        },
        {
          "command": "bobBazaar.reviewRangeWithProjectRules"
        },
        {
          "command": "bobBazaar.validateReviewResultJson"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.106.0",
    "typescript": "^5.4.5",
    "@vscode/vsce": "^3.2.1"
  }
}
